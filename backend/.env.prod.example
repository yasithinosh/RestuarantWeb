# Production Environment Variables
# Use 'nano backend/.env.prod' to edit this file on your server.
# NEVER commit the actual .env.prod file to version control.

PORT=5000

# PostgreSQL (Production)
# CHANGE THESE!
DB_HOST=postgres
DB_PORT=5432
DB_NAME=labellacucina
DB_USER=labella
DB_PASS=labella_CHANGE_ME_NOW_12345

# JWT (Production)
# Generate a long random string: openssl rand -base64 32
JWT_SECRET=labella_production_secret_key_change_me

# PayHere (Live/Sandbox)
# For production, set SANDBOX=false and use live credentials
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_SECRET=your_merchant_secret
PAYHERE_SANDBOX=false

# URLs
CLIENT_URL=https://labella.inovoid.me

# Admin Seed Account (for scripts/seed-admin.js)
ADMIN_EMAIL=admin@inovoid.me
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY_998877
